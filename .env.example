# Database Configuration
# Local: postgresql://postgres:your_password@localhost:5432/staffos_dev
# Render (use full hostname + ssl): postgresql://user:pass@dpg-xxxxx-a.singapore-postgres.render.com/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/staffos_dev"
# Optional: remote Postgres cold start (ms). Default 60000.
# PG_CONNECTION_TIMEOUT_MS=60000
# PG_POOL_MAX=15

# Environment
NODE_ENV=development

# Session & Security
SESSION_SECRET=your-secret-key-here

# Email Service
FROM_EMAIL=StaffOS <onboarding@resend.dev>

# Google OAuth - Backend Only (Node.js)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth - Frontend Only (Vite) 
# Available via: import.meta.env.VITE_GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Deployment
REPLIT_DEV_DOMAIN=your-replit-domain.replit.dev
FRONTEND_URL=https://your-frontend-domain.vercel.app
BACKEND_URL=https://your-api.onrender.com
# Frontend (Vercel) — required for resume iframe preview in production
VITE_API_URL=https://your-api.onrender.com

# Resume parsing (single + bulk import on Master Database)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# Parallel bulk parses per request (2–12, default 6). Keep ≤6 on Render to avoid proxy timeouts.
BULK_PARSE_CONCURRENCY=6
